<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Fetch Masters 2026 scores every 15 minutes during tournament hours (April 9-12)</Description>
  </RegistrationInfo>
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-04-09T07:45:00</StartBoundary>
      <EndBoundary>2026-04-09T20:15:00</EndBoundary>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT12H30M</Duration>
      </Repetition>
      <Enabled>true</Enabled>
    </CalendarTrigger>
    <CalendarTrigger>
      <StartBoundary>2026-04-10T07:45:00</StartBoundary>
      <EndBoundary>2026-04-10T20:15:00</EndBoundary>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT12H30M</Duration>
      </Repetition>
      <Enabled>true</Enabled>
    </CalendarTrigger>
    <CalendarTrigger>
      <StartBoundary>2026-04-11T07:45:00</StartBoundary>
      <EndBoundary>2026-04-11T20:15:00</EndBoundary>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT12H30M</Duration>
      </Repetition>
      <Enabled>true</Enabled>
    </CalendarTrigger>
    <CalendarTrigger>
      <StartBoundary>2026-04-12T07:45:00</StartBoundary>
      <EndBoundary>2026-04-12T20:15:00</EndBoundary>
      <Repetition>
        <Interval>PT15M</Interval>
        <Duration>PT12H30M</Duration>
      </Repetition>
      <Enabled>true</Enabled>
    </CalendarTrigger>
  </Triggers>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>true</RunOnlyIfNetworkAvailable>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <ExecutionTimeLimit>PT5M</ExecutionTimeLimit>
  </Settings>
  <Actions>
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-ExecutionPolicy Bypass -File "C:\Users\jdpoo\Documents\GitHub\masters2024\update.bat"</Arguments>
      <WorkingDirectory>C:\Users\jdpoo\Documents\GitHub\masters2024</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
